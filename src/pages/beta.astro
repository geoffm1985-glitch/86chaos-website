---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Apply for 86 Chaos Founder Beta";
const description = "Apply for the 86 Chaos Founder Beta and help shape a restaurant operations app built by a working kitchen manager for real shifts.";
const ogTitle = "Apply for 86 Chaos Founder Beta";
const ogDescription = "Apply for the 86 Chaos Founder Beta and help shape a restaurant operations app built by a working kitchen manager for real shifts.";
---

<BaseLayout
  title={title}
  description={description}
  page="beta"
  canonicalPath="/beta.html"
  ogTitle={ogTitle}
  ogDescription={ogDescription}
>
<main id="main">
<section class="page-hero compact-hero">
      <div class="container">
        <div class="reveal">
          <p class="eyebrow">Limited Founder Beta</p>
          <h1>90 days free to prove it belongs in your kitchen.</h1>
          <p class="page-lede">86 Chaos helps restaurants manage prep, 86s, schedules, ordering, reminders, inventory, maintenance, and daily manager visibility. Apply to join a limited group of independent restaurants helping shape the product before paid launch.</p>
          <div class="chip-row"><span>No credit card</span><span>No purchase required</span><span>Unlimited users</span><span>Free setup</span><span>50% off first location</span></div>
        </div>
        <div class="phone-frame reveal delay-1"><img src="assets/maintenance.webp" alt="86 Chaos Maintenance Center screen" /></div>
      </div>
    </section>
    <section class="section">
      <div class="container form-grid">
        <div class="card reveal">
          <p class="eyebrow">What beta restaurants receive</p>
          <h2>A rare chance to test the full value before paying.</h2>
          <ul>
            <li>90 days of free Founder Beta access.</li>
            <li>No credit card and no purchase required.</li>
            <li>Free hands-on setup help during beta.</li>
            <li>Direct input into what gets improved, simplified, and built next.</li>
            <li>First access to new features where the selected plan allows.</li>
            <li>50% off the first location for the first paid year after beta.</li><li>Owner Pro additional locations stay full price at $129/month.</li>
          </ul>
        </div>
        <div class="reveal delay-1">
          <form class="beta-form panel" data-beta-form action="/api/beta-application" method="post">
            <label class="honeypot">Leave this blank<input name="website" tabindex="-1" autocomplete="off" /></label>
            <div class="form-row">
              <label>Your name<input name="name" required placeholder="Alex Rivera" autocomplete="name" /></label>
              <label>Restaurant<input name="restaurant" required placeholder="Ridge & Rail Tavern" /></label>
            </div>
            <label>Restaurant address<input name="address" required placeholder="123 Main St" autocomplete="street-address" /></label>
            <div class="form-row">
              <label>City and state<input name="location" required placeholder="Chilton, WI" autocomplete="address-level2" /></label>
              <label>Email<input name="email" type="email" required placeholder="owner@example.com" autocomplete="email" /></label>
            </div>
            <div class="form-row">
              <label>Phone<input name="phone" type="tel" required placeholder="920-555-0186" autocomplete="tel" /></label>
              <label>Plan you are most curious about<select name="plan"><option>Not sure yet</option><option>Shift</option><option>Operations</option><option>Smart Kitchen</option><option>Owner Pro</option></select></label>
            </div>
            <label>Best time to contact<input name="contact_time" required placeholder="Weekdays after 2pm, mornings, etc." autocomplete="off" /></label>
            <label>Biggest headache<textarea name="headache" required placeholder="Prep gets missed, inventory is messy, daily close takes forever..."></textarea></label>
            <label>Anything else, optional<textarea name="message" placeholder="Tell me what kind of restaurant you run or what you want to test first."></textarea></label>
            <button class="button full" type="submit" data-submit-text="Apply Free">Apply Free</button>
            <p class="form-status" data-form-status role="status"></p>
          </form>

        <div class="note-box beta-legal-note">
          <strong>Beta and backup note</strong>
          <span>Founder Beta is for testing and feedback. Restaurants should keep their own off-platform backups of important records, and AI suggestions should be reviewed by a person before business decisions are made. By applying, you agree that use is subject to the applicable <a href="legal.html">Legal / Terms</a>.</span>
        </div>

        </div>
      </div>
    </section>

    
    
    <section class="section ai-tier-breakdown">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">Built from real kitchen feedback</p>
          <h2>Help shape the parts that matter during an actual shift.</h2>
          <p>The most valuable feedback is practical: Does it save manager time? Does 86Voice make the app easier to use? Do order drafts, price warnings, waste/par insights, Menu Intelligence, Smart Prep Matching, and Manager Brief make the restaurant easier to run?</p>
        </div>
        <div class="ai-suite-card panel reveal delay-1">
          <p class="eyebrow">Start with one useful win</p>
          <h3>Free setup keeps the first step manageable.</h3>
          <p>Choose prep, 86 alerts, schedules, reminders, ordering, inventory, or another pain point. Set up that workflow first, then add more only when the team is ready.</p>
        </div>
      </div>
    </section>

    <section class="section ai-tools-section">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">Smart Kitchen beta focus</p>
          <h2>Test the strongest intelligence tools on real restaurant data.</h2>
          <p>Founder Beta restaurants can help refine 86Voice, AI-assisted ordering, Manager Brief intelligence, Menu Intelligence, invoice price warnings, waste/par analysis, prep prediction, forecasting, and human-reviewed recommendations.</p>
          <a class="button" href="ai-tools.html">Review AI Tools</a>
        </div>
        <div class="ai-suite-card panel reveal delay-1">
          <p class="eyebrow">Useful feedback</p>
          <h3>Tell us what actually saves time.</h3>
          <p>The best beta feedback is whether AI suggestions are helpful, clear, safe, and faster than the old way.</p>
        </div>
      </div>
    </section>

    <section class="section feature-band">
      <div class="container grid-3">
        <div class="note-box reveal"><strong>1. Quick fit check</strong><span>We confirm the restaurant is a good fit for the limited beta and follow up at the contact time you listed.</span></div>
        <div class="note-box reveal delay-1"><strong>2. Start with one pain point</strong><span>We choose the first workflow to test and help set up the minimum needed to make it useful.</span></div>
        <div class="note-box reveal delay-2"><strong>3. Shape the product</strong><span>Your feedback helps decide what gets refined before launch, especially for independent bars and kitchens.</span></div>
      </div>
    </section>

  </main>
  <section class="cta-band">
    <div class="container">
      <div class="cta-card">
        <div>
          <span class="eyebrow">Founder Beta</span>
          <h2>Try 86 Chaos free for 90 days.</h2>
          <p>90 days free, no credit card, no purchase required, and free setup during beta. Accepted restaurants help shape the product and receive 50% off the first location for the first paid year.</p>
        </div>
        <a class="button" href="beta.html">Apply Free</a>
      </div>
    </div>
  </section>
</BaseLayout>
