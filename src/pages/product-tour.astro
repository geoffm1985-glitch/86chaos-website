---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "86 Chaos Product Tour | Real App Screens";
const description = "Tour seven polished 86 Chaos product screens with realistic demo data for manager brief, prep, schedule builder, AI ordering, menu impact, inventory, and 86Voice.";
const ogTitle = "86 Chaos Product Tour | Real App Screens";
const ogDescription = "Tour seven polished 86 Chaos product screens with realistic demo data for manager brief, prep, schedule builder, AI ordering, menu impact, inventory, and 86Voice.";
---

<BaseLayout
  title={title}
  description={description}
  page="tour"
  canonicalPath="/product-tour.html"
  ogTitle={ogTitle}
  ogDescription={ogDescription}
>
<main id="main">

    <section class="page-hero compact-hero tour-hero">
      <div class="container">
        <div class="reveal">
          <p class="eyebrow">Product Tour</p>
          <h1>Seven screens that show the daily kitchen picture.</h1>
          <p class="page-lede">The tour uses clean demo data, but the product is being tested in a real kitchen by the founder during actual restaurant work. </p>
        <p class="page-lede">This tour uses clean demo data so owners can picture the app during a real shift: priorities, prep, scheduling, ordering, menu impact, inventory, invoices, and voice commands without exposing private restaurant information.</p>
          <div class="chip-row tour-chips">
            <span>Demo data, not private records</span>
            <span>6 to 7 core screens</span>
            <span>Built for quick owner scanning</span>
          </div>
        </div>
        <div class="tour-mini-board panel reveal delay-1">
          <p class="eyebrow">Demo Kitchen</p>
          <h3>Friday service snapshot</h3>
          <div class="mini-row"><strong>Open prep</strong><span>14 items</span></div>
          <div class="mini-row"><strong>Active 86s</strong><span>2 alerts</span></div>
          <div class="mini-row"><strong>Order draft</strong><span>Ready for review</span></div>
          <div class="mini-row good"><strong>Owner view</strong><span>Updated 4:12 PM</span></div>
        </div>
      </div>
    </section>

    <section class="section tour-intro-strip">
      <div class="container section-head center reveal">
        <p class="eyebrow">What the tour should prove</p>
        <h2>Not every feature needs a screenshot. These seven show the whole operating story.</h2>
        <p>The goal is not to document every button. The goal is to show that 86 Chaos can organize the shift, connect kitchen information, and give managers a clear next move.</p>
      </div>
    </section>

    <section class="section tour-demo-section">
      <div class="container tour-demo-stack">

        <article class="tour-demo-card reveal">
          <div class="tour-copy">
            <span class="tour-number">01</span>
            <p class="eyebrow">Manager Brief</p>
            <h2>Start with what needs attention.</h2>
            <p>Shows owners and managers the current shift picture without hunting through schedules, prep lists, messages, and inventory screens.</p>
            <ul class="tour-why-list">
              <li>Best first impression for the Product Tour.</li>
              <li>Explains the app faster than a feature list.</li>
              <li>Turns daily noise into a clear priority board.</li>
            </ul>
          </div>
          <div class="mock-screen">
            <div class="mock-top"><strong>Manager Brief</strong><span>Friday 4:12 PM</span></div>
            <div class="mock-stat-grid">
              <div><b>14</b><span>open prep</span></div>
              <div><b>2</b><span>active 86s</span></div>
              <div><b>3</b><span>low stock</span></div>
              <div><b>1</b><span>maintenance</span></div>
            </div>
            <div class="mock-list">
              <div class="mock-item urgent"><strong>Ranch below par</strong><span>Menu impact: wings, wraps, salads</span></div>
              <div class="mock-item"><strong>Saturday event prep</strong><span>Pull 12 lb chicken, prep 4 pans onions</span></div>
              <div class="mock-item"><strong>Walk-in gasket issue</strong><span>Logged, photo attached, repair follow-up due</span></div>
            </div>
            <div class="mock-actions"><span>86 Alert</span><span>Prep</span><span>Message</span><span>Fix It</span></div>
          </div>
        </article>

        <article class="tour-demo-card reverse reveal">
          <div class="tour-copy">
            <span class="tour-number">02</span>
            <p class="eyebrow">Prep & Tasks</p>
            <h2>Show the kitchen actually moving.</h2>
            <p>This is one of the strongest screens because every independent kitchen understands prep, quantities, responsibility, and done status.</p>
            <ul class="tour-why-list">
              <li>Shows practical daily use, not a polished fantasy dashboard.</li>
              <li>Highlights smart prep matching and real quantities.</li>
              <li>Easy for cooks and managers to understand immediately.</li>
            </ul>
          </div>
          <div class="mock-screen">
            <div class="mock-top"><strong>Prep & Tasks</strong><span>Station view</span></div>
            <div class="mock-progress"><span style="width:68%"></span></div>
            <div class="mock-list compact">
              <div class="mock-item done"><strong>House ranch</strong><span>3 qt complete • cold side</span></div>
              <div class="mock-item"><strong>Chop onions</strong><span>4 pans needed • 2 done</span></div>
              <div class="mock-item urgent"><strong>Wing sauce backup</strong><span>Due before dinner rush</span></div>
              <div class="mock-item"><strong>Portion burger patties</strong><span>48 count • grill station</span></div>
            </div>
          </div>
        </article>

        <article class="tour-demo-card reveal">
          <div class="tour-copy">
            <span class="tour-number">03</span>
            <p class="eyebrow">Schedule Builder</p>
            <h2>Show staffing without showing private payroll.</h2>
            <p>Shift includes Schedule Builder, so this belongs in the tour. It should show coverage and availability, not the Time Clock.</p>
            <ul class="tour-why-list">
              <li>Supports the lower-priced Shift plan clearly.</li>
              <li>Shows schedule organization without wage data.</li>
              <li>Gives owners another everyday reason to try the beta.</li>
            </ul>
          </div>
          <div class="mock-screen schedule-mock">
            <div class="mock-top"><strong>Schedule Builder</strong><span>Week of Aug 3</span></div>
            <div class="schedule-grid-demo">
              <b>Mon</b><b>Tue</b><b>Wed</b><b>Thu</b><b>Fri</b>
              <span>Prep<br>10-4</span><span>Line<br>11-7</span><span>Fryer<br>4-10</span><span>Expo<br>5-10</span><span>Lead<br>2-10</span>
              <span>Line<br>4-10</span><span>Prep<br>10-2</span><span>Lead<br>2-9</span><span>Line<br>11-7</span><span>Fryer<br>4-11</span>
            </div>
            <div class="mock-note">Coverage warning: Friday dinner needs one more line cook.</div>
          </div>
        </article>

        <article class="tour-demo-card reverse reveal">
          <div class="tour-copy">
            <span class="tour-number">04</span>
            <p class="eyebrow">AI Ordering</p>
            <h2>Replace ordering guesswork with a reviewable draft.</h2>
            <p>AI Ordering is the clearest Smart Kitchen sales hook. It shows how inventory, par, invoices, events, and prep can become a manager-approved order draft.</p>
            <ul class="tour-why-list">
              <li>Shows real dollar value, not just organization.</li>
              <li>Connects inventory, events, prep, and purchasing.</li>
              <li>Human review stays obvious and professional.</li>
            </ul>
          </div>
          <div class="mock-screen order-mock">
            <div class="mock-top"><strong>AI Ordering</strong><span>Draft ready</span></div>
            <div class="mock-list compact">
              <div class="mock-item"><strong>Sysco</strong><span>Chicken breast 40 lb • fryer oil 2 jugs</span></div>
              <div class="mock-item"><strong>Produce vendor</strong><span>Onions 25 lb • lettuce 2 cases • tomatoes 1 case</span></div>
              <div class="mock-item urgent"><strong>Review warning</strong><span>Ranch usage up 22% from wing special</span></div>
            </div>
            <div class="mock-actions"><span>Review</span><span>Edit</span><span>Save Draft</span></div>
          </div>
        </article>

        <article class="tour-demo-card reveal">
          <div class="tour-copy">
            <span class="tour-number">05</span>
            <p class="eyebrow">Menu Impact & 86 Alerts</p>
            <h2>Show what breaks when one item runs out.</h2>
            <p>This screen explains why 86 Chaos is more than a list app. If an ingredient is out, managers can see the affected menu items and communicate faster.</p>
            <ul class="tour-why-list">
              <li>Strong visual proof of Menu Intelligence.</li>
              <li>Easy for restaurant people to understand.</li>
              <li>Connects inventory problems to guest-facing menu problems.</li>
            </ul>
          </div>
          <div class="mock-screen impact-mock">
            <div class="mock-top"><strong>Menu Impact</strong><span>Ingredient: ranch</span></div>
            <div class="mock-list compact">
              <div class="mock-item urgent"><strong>86 risk</strong><span>Buffalo wrap • chicken bacon ranch • wing baskets</span></div>
              <div class="mock-item"><strong>Substitute note</strong><span>Offer blue cheese or chipotle sauce if approved</span></div>
              <div class="mock-item done"><strong>Message drafted</strong><span>Ready for kitchen board and manager review</span></div>
            </div>
          </div>
        </article>

        <article class="tour-demo-card reverse reveal">
          <div class="tour-copy">
            <span class="tour-number">06</span>
            <p class="eyebrow">Inventory & Invoice Watch</p>
            <h2>Catch low stock and price changes earlier.</h2>
            <p>Owners care about food cost. This screen should show par, low stock, vendor history, and invoice warnings in plain language.</p>
            <ul class="tour-why-list">
              <li>Turns the app into a cost-protection tool.</li>
              <li>Shows why scans and invoices matter.</li>
              <li>Works well for Smart Kitchen and Owner Pro.</li>
            </ul>
          </div>
          <div class="mock-screen inventory-mock">
            <div class="mock-top"><strong>Inventory Watch</strong><span>Price review</span></div>
            <div class="mock-list compact">
              <div class="mock-item urgent"><strong>Fryer oil</strong><span>$37.80 now • was $31.45 • up 20%</span></div>
              <div class="mock-item"><strong>Chicken breast</strong><span>22 lb on hand • par 40 lb • reorder suggested</span></div>
              <div class="mock-item done"><strong>Invoice scan</strong><span>18 items matched to vendor history</span></div>
            </div>
          </div>
        </article>

        <article class="tour-demo-card reveal">
          <div class="tour-copy">
            <span class="tour-number">07</span>
            <p class="eyebrow">86Voice</p>
            <h2>Make the app faster during the shift.</h2>
            <p>86Voice is the differentiator people remember. Show simple commands that create prep, check status, open AI Ordering, and start an 86 alert.</p>
            <ul class="tour-why-list">
              <li>Memorable feature for owners and managers.</li>
              <li>Shows the app can be used while work is happening.</li>
              <li>Connects to prep, 86s, reminders, and AI Ordering.</li>
            </ul>
          </div>
          <div class="mock-screen voice-mock">
            <div class="mock-top"><strong>86Voice</strong><span>Listening</span></div>
            <div class="voice-bubble"><b>Say:</b> “Add four pans of onions to prep.”</div>
            <div class="voice-bubble response"><b>86 Chaos:</b> Found existing onion prep. Updated quantity to 4 pans.</div>
            <div class="voice-bubble"><b>Say:</b> “Open AI Ordering.”</div>
            <div class="mock-actions"><span>Prep</span><span>86 Alert</span><span>AI Ordering</span></div>
          </div>
        </article>

      </div>
    </section>

    <section class="section feature-band">
      <div class="container split">
        <div class="reveal">
          <p class="eyebrow">Built for real shift flow</p>
          <h2>See how the pieces work together during service.</h2>
          <p>The tour follows the work managers actually chase: prep, schedules, 86s, ordering, inventory, invoices, and shift priorities. Each panel uses clean demo data so owners can picture how 86 Chaos fits into their own kitchen without exposing private restaurant information.</p>
        </div>
        <div class="panel tour-check-panel reveal delay-1">
          <h3>One practical operations layer.</h3>
          <p>Manager Brief keeps the day visible. AI Ordering turns stock, par, events, and invoice history into a reviewable draft. Menu Impact shows what changes when an item runs out.</p>
          <p>86Voice helps managers move faster while the work is happening, without turning the app into another desk-only tool.</p>
        </div>
      </div>
    </section>

  </main>
  <section class="cta-band">
    <div class="container">
      <div class="cta-card">
        <div>
          <span class="eyebrow">Founder Beta</span>
          <h2>Try 86 Chaos free for 90 days.</h2>
          <p>90 days free, no credit card, no purchase required, and free setup during beta. Accepted restaurants help shape the product and receive 50% off the first location for the first paid year.</p>
        </div>
        <a class="button" href="beta.html">Apply Free</a>
      </div>
    </div>
  </section>
</BaseLayout>
