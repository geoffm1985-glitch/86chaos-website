---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';

const {
  title = '86 Chaos | Kitchen Management OS for Independent Restaurants',
  description = '86 Chaos helps independent restaurants save manager time, improve ordering decisions, protect food cost, and keep daily operations visible.',
  page = '',
  canonicalPath = '/',
  ogTitle = title,
  ogDescription = description,
  ogImage = 'https://86chaos.com/assets/map-logo.webp',
  noindex = false
} = Astro.props;
const canonicalUrl = canonicalPath.startsWith('http') ? canonicalPath : `https://86chaos.com${canonicalPath}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex" />}
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta name="theme-color" content="#0b1117" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="assets/app-icon.webp" />
  <link rel="apple-touch-icon" href="assets/app-icon.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css?v=94" />
  <Analytics />
  <slot name="head" />
</head>
<body data-page={page}>
  <a class="skip-link" href="#main">Skip to content</a>
  <Header activePage={page} />
  <slot />
  <Footer />
  <script is:inline src="script.js?v=94"></script>
</body>
</html>
